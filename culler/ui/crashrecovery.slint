import { Theme } from "theme.slint";

// culler/ui/crashrecovery.slint — DESIGN.md §4 screen 2d: the crash-recovery
// startup screen (Task A3). Shown INSTEAD of the culling view whenever
// `startup::find_startup_crash` detects an interrupted apply at launch — the
// backdrop is the startup gradient (shared with 2a), not a scrim over a
// photo, since this screen exists before culling ever starts. Buttons are
// custom Rectangle+TouchArea, matching applydialog.slint/keysheet.slint
// convention (no std-widgets Button).
export component CrashRecovery inherits Rectangle {
    in property <string> journal-path;
    in property <int> done;
    in property <int> total;
    in property <string> report-text; // journal_report output; empty until Show report
    in property <bool> report-open;
    in property <bool> resuming; // true while the worker runs

    callback show-report();
    callback resume();

    // Opaque startup gradient (DESIGN §2.2/§5) — covers the culling view
    // behind it entirely, unlike ApplyDialog's translucent scrim.
    background: @radial-gradient(circle, Theme.bg-radial-in 0%, Theme.bg-radial-out 70%);

    panel := Rectangle {
        width: 520px;
        // Fixed height, not bound to the content VerticalLayout's preferred-height
        // (same binding-loop hazard applydialog.slint/hud.slint already disclose):
        // this Rectangle isn't managed by an outer layout, so an unconstrained
        // height defaults to 100% of its parent (the full window). Two content
        // shapes — report closed / report open — get their own fixed height,
        // mirroring ApplyDialog's `apply-running ? … : (preview-ready ? … : …)`
        // height ternary.
        height: root.report-open ? 410px : 260px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.panel-dialog;
        border-radius: Theme.r-xl;
        border-width: 1px;
        // DESIGN §2d gold border `rgba(210,165,69,.35)` — a structural accent
        // color (like applydialog.slint's shadow), not a Theme-token duplicate.
        border-color: #d2a54559;
        clip: true;
        // DESIGN §2.6 dialog shadow `0 16px 50px rgba(0,0,0,.6)` — a structural
        // shadow color (like the filmstrip dot-ring), not a Theme-token duplicate.
        drop-shadow-offset-y: 16px;
        drop-shadow-blur: 50px;
        drop-shadow-color: #00000099;

        VerticalLayout {
            padding: 20px;
            spacing: 10px;

            HorizontalLayout {
                height: 40px;
                spacing: 10px;
                badge := Rectangle {
                    width: 40px;
                    height: 40px;
                    border-radius: 20px;
                    background: transparent;
                    border-width: 1.5px;
                    border-color: Theme.accent-warn;
                    Text {
                        text: "!";
                        font-family: Theme.font-mono;
                        font-weight: 600;
                        font-size: 16px;
                        color: Theme.accent-warn;
                        width: parent.width;
                        height: parent.height;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Text {
                    text: "Interrupted apply found";
                    font-family: Theme.font-sans;
                    font-weight: 600;
                    font-size: 15px;
                    color: Theme.text;
                    vertical-alignment: center;
                }
            }

            Text {
                text: "journal: " + root.journal-path;
                font-family: Theme.font-mono;
                font-size: 12px;
                color: Theme.text-dim;
                wrap: word-wrap;
            }

            // Counts line: green N/M via adjacent Text runs, muted connective
            // words (DESIGN §2d "N of M moves completed"). Thousands-separator
            // commas on N/M are OPTIONAL polish (§2d screenshot shows "1,237
            // of 2,000") — not implemented here; plain ints are rendered.
            HorizontalLayout {
                spacing: 0px;
                alignment: start;
                Text {
                    text: root.done;
                    font-family: Theme.font-mono;
                    font-size: 12px;
                    color: Theme.accent-confirm;
                }
                Text {
                    text: " of ";
                    font-family: Theme.font-mono;
                    font-size: 12px;
                    color: Theme.text-muted;
                }
                Text {
                    text: root.total;
                    font-family: Theme.font-mono;
                    font-size: 12px;
                    color: Theme.accent-confirm;
                }
                Text {
                    text: " moves completed";
                    font-family: Theme.font-mono;
                    font-size: 12px;
                    color: Theme.text-muted;
                }
            }

            Text {
                text: "every completed move is recorded — nothing was deleted";
                font-family: Theme.font-mono;
                font-size: 11.5px;
                color: Theme.label;
            }

            track := Rectangle {
                height: 6px;
                border-radius: Theme.r-sm;
                background: Theme.input-inset;
                fill := Rectangle {
                    x: 0px;
                    y: 0px;
                    height: parent.height;
                    width: parent.width * (root.total > 0 ? root.done / root.total : 0);
                    border-radius: Theme.r-sm;
                    background: Theme.accent-warn;
                }
            }

            if root.report-open: Rectangle {
                height: 140px;
                background: Theme.input-inset;
                border-radius: Theme.r-md;
                border-width: 1px;
                border-color: Theme.border-input;
                Text {
                    text: root.report-text;
                    font-family: Theme.font-mono;
                    font-size: 11px;
                    color: Theme.text-2;
                    wrap: word-wrap;
                    x: 10px;
                    y: 10px;
                    width: parent.width - 20px;
                }
            }

            if root.resuming: Text {
                text: "Resuming…";
                font-family: Theme.font-mono;
                font-size: 12px;
                color: Theme.text-muted;
            }

            // Footer buttons, HIDDEN while resuming (§2d: no keyboard dismiss,
            // no Cancel — the only exits are Show report / Resume apply).
            if !root.resuming: HorizontalLayout {
                alignment: end;
                spacing: 8px;
                report-btn := Rectangle {
                    height: 34px;
                    width: report-btn-text.preferred-width + 24px;
                    background: transparent;
                    border-radius: Theme.r-md;
                    border-width: 1px;
                    border-color: Theme.border-btn;
                    report-btn-text := Text {
                        text: "Show report";
                        font-family: Theme.font-sans;
                        font-weight: 600;
                        font-size: 13px;
                        color: Theme.text-muted;
                        x: (parent.width - self.width) / 2;
                        vertical-alignment: center;
                    }
                    TouchArea { clicked => { root.show-report(); } }
                }
                resume-btn := Rectangle {
                    height: 34px;
                    width: resume-btn-text.preferred-width + 24px;
                    background: Theme.accent-warn;
                    border-radius: Theme.r-md;
                    resume-btn-text := Text {
                        text: "Resume apply";
                        font-family: Theme.font-sans;
                        font-weight: 600;
                        font-size: 13px;
                        color: Theme.on-accent;
                        x: (parent.width - self.width) / 2;
                        vertical-alignment: center;
                    }
                    TouchArea { clicked => { root.resume(); } }
                }
            }
        }
    }
}
