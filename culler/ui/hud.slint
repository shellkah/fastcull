import { LineEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { TagSuggestion } from "globals.slint";

// culler/ui/hud.slint — floating HUD overlays + tag entry (DESIGN.md §4 screens 1b/2f).
// Per task-9 corrections: the HUD is NOT a side column — it is a set of small
// `Theme.panel-hud` panels that float OVER the full-bleed photo, inset 14px from the
// loupe edges. Each exported component's ROOT element is transparent and fills its
// container (the loupe "stage" Rectangle in app.slint, via Slint's default "100% of
// parent when not part of a layout" sizing — builtins.slint); a nested `panel`
// Rectangle inside does the actual inset positioning.
//
// Syntax adaptation (disclosed): a component's root element cannot reference `parent`
// (the compiler rejects it — "Cannot access id 'parent'" — because a reusable
// component's root doesn't know its eventual container at definition time). Nesting
// the real panel one level down makes `parent` resolve to the root element within the
// *same* component, which is legal (same pattern filmstrip.slint already uses for its
// tier-dot badges, just one level shallower there since it isn't anchoring to the
// grandparent).
//
// Sizing note (also disclosed): panels use fixed pixel width/height rather than
// binding to an inner layout's `preferred-width`/`preferred-height`. A Rectangle not
// managed by an outer layout defaults its own size to 100% of ITS parent, so an inner
// layout filling such a Rectangle would in turn default to 100% of that Rectangle too
// — feeding the Rectangle's width from the inner layout's preferred size while the
// inner layout's own width silently depends back on the Rectangle's width is exactly
// the shape of the "binding loop" cases the Slint compiler rejects. Fixed pixel sizing
// (as the task brief's own TagEntry sketch already used) avoids that risk entirely;
// content here is short/bounded strings so this is safe. The one exception is the
// tier badge's width, bound to a *leaf* Text's `preferred-width` (font-metric based,
// not itself dependent on an ancestor's width) — a standard, non-circular Slint idiom.

// Maps a HudText.tier display string ("Rest"/"Keep"/"Pick"/"Best"/"Reject") to the
// palette code `Theme.tier-color` / `ui::tier_color_code` expect (0..4). Slint has no
// top-level free functions (only component/global members), so this lives as a
// `global` helper rather than a free `pure function` — a syntax adaptation. The pure
// HudText/hud_text interface (task-9 amendment 3) intentionally stays a display
// String, not a code; this is a presentation-only derivation local to the .slint
// side, disclosed here rather than adding a second Rust-side property.
export global TierCode {
    public pure function for-name(name: string) -> int {
        return name == "Keep" ? 1 : name == "Pick" ? 2 : name == "Best" ? 3 : name == "Reject" ? 4 : 0;
    }
}

// ── top-left: filename + RAW badge + N/M position (DESIGN §4 1b) ──
export component HudTopLeft inherits Rectangle {
    in property <string> filename;
    in property <bool> has-raw;
    in property <string> position;
    background: transparent;

    panel := Rectangle {
        x: 14px;
        y: 14px;
        width: 300px;
        height: 26px;
        background: Theme.panel-hud;
        border-radius: Theme.r-md;
        border-width: 1px;
        border-color: Theme.border;

        HorizontalLayout {
            padding: 7px;
            spacing: 8px;
            alignment: start;
            Text {
                text: root.filename;
                font-family: Theme.font-mono;
                font-weight: 500;
                font-size: 12px;
                color: Theme.text;
                vertical-alignment: center;
            }
            if root.has-raw: Rectangle {
                border-radius: Theme.r-sm;
                border-width: 1px;
                // DESIGN §2.3 RAW-badge border — not a Theme ramp value, literal by spec.
                border-color: #45484e;
                HorizontalLayout {
                    padding: 3px;
                    Text {
                        text: "RAW";
                        font-family: Theme.font-mono;
                        font-weight: 600;
                        font-size: 9px;
                        color: Theme.text;
                        vertical-alignment: center;
                    }
                }
            }
            Text {
                text: root.position;
                font-family: Theme.font-mono;
                font-size: 10.5px;
                color: Theme.text-dim;
                vertical-alignment: center;
            }
        }
    }
}

// ── top-right: per-tier counts pill + current-tier badge (DESIGN §4 1b) ──
export component HudTopRight inherits Rectangle {
    in property <string> tier; // display text: "Rest"/"Keep"/"Pick"/"Best"/"Reject"
    // Per-tier counts pill ints. Defaults 0; Task 11 wires these from `session.counts()`
    // (task-9 amendment 5 — HudText.counts stays a formatted String for the tests, the
    // pill renders from these five ints so each dot+number is independently colorable).
    in property <int> count-best: 0;
    in property <int> count-pick: 0;
    in property <int> count-keep: 0;
    in property <int> count-rest: 0;
    in property <int> count-reject: 0;
    background: transparent;

    // DESIGN §4 1b / screens/1b-main.png: the counts pill and the current-tier
    // badge are two visually distinct rounded shapes with a gap between them
    // (the badge alone carries the §2.6 shadow) — not one merged panel. Laid
    // out here as two independently-positioned Rectangles, badge rightmost.
    badge := Rectangle {
        x: parent.width - self.width - 14px;
        y: 14px;
        height: 30px;
        background: Theme.tier-color(TierCode.for-name(root.tier));
        border-radius: Theme.r-md;
        width: badge-text.preferred-width + 14px;
        // DESIGN §2.6 HUD-badge shadow `0 2px 8px rgba(0,0,0,.4)` — a
        // structural shadow color (like the filmstrip dot-ring), not a
        // Theme-token duplicate.
        drop-shadow-offset-y: 2px;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000066;
        badge-text := Text {
            text: root.tier == "Rest" ? "REST" : root.tier.to-uppercase();
            font-family: Theme.font-mono;
            font-weight: 600;
            font-size: 12px;
            letter-spacing: 1px;
            color: Theme.on-accent;
            x: 7px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }

    counts-panel := Rectangle {
        x: badge.x - self.width - 8px;
        y: 14px;
        height: 30px;
        width: counts-row.preferred-width + 14px;
        background: Theme.panel-hud;
        border-radius: Theme.r-md;
        border-width: 1px;
        border-color: Theme.border;

        counts-row := HorizontalLayout {
            padding: 7px;
            spacing: 6px;
            alignment: center;
            // order: best · pick · keep · rest · reject
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.tier-best; }
            Text { text: root.count-best; font-family: Theme.font-mono; font-size: 10.5px; color: Theme.text-muted; vertical-alignment: center; }
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.tier-pick; }
            Text { text: root.count-pick; font-family: Theme.font-mono; font-size: 10.5px; color: Theme.text-muted; vertical-alignment: center; }
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.tier-keep; }
            Text { text: root.count-keep; font-family: Theme.font-mono; font-size: 10.5px; color: Theme.text-muted; vertical-alignment: center; }
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.tier-rest; }
            Text { text: root.count-rest; font-family: Theme.font-mono; font-size: 10.5px; color: Theme.text-muted; vertical-alignment: center; }
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.tier-reject; }
            Text { text: root.count-reject; font-family: Theme.font-mono; font-size: 10.5px; color: Theme.text-muted; vertical-alignment: center; }
        }
    }
}

// ── bottom-left: luma histogram + EXIF line + tag chip + filter + progress
// (DESIGN §4 1b). The histogram + EXIF line were §6 "Defer"; they are now built
// to match screens/1b-main.png. The existing filter-label + `seen` progress are
// kept below them (they're a v1 addition not shown in 1b). Panel height is
// computed from which optional rows are present — this Rectangle isn't in a
// layout, so it can't auto-size to content without the binding-loop hazard the
// header comment discloses; every row therefore has a fixed height and the sum
// is exact. Rows (top→bottom): histogram(34) · [exif(15)] · [tags(20)] ·
// filter(15) · progress(15), padding 8, spacing 6.
export component HudBottomLeft inherits Rectangle {
    // Comma-joined tags straight from HudText.tags (the pure interface keeps this a
    // single String, not a list — see task-9 report for the disclosed single-chip
    // simplification vs. DESIGN's per-tag chip row).
    in property <string> tags;
    in property <string> filter-label;
    in property <string> progress;
    // Preformatted "1/250s · ƒ2.8 · ISO 400 · 85mm" from `ExifSummary::hud_line`
    // (empty when the shot has no exposure EXIF).
    in property <string> exif;
    // 30 normalized [0,1] luma-bar heights from `culler_core::histogram`.
    in property <[float]> histogram;
    background: transparent;

    panel := Rectangle {
        x: 14px;
        y: parent.height - self.height - 14px;
        width: 280px;
        height: 92px
              + (root.exif != "" ? 21px : 0px)
              + (root.tags != "" ? 26px : 0px);
        background: Theme.panel-hud;
        border-radius: Theme.r-md;
        border-width: 1px;
        border-color: Theme.border;

        VerticalLayout {
            padding: 8px;
            spacing: 6px;
            alignment: start;

            // Luma histogram — 30 bars, bottom-anchored, DESIGN §4 1b. Always
            // present (blank until the first decode) so the panel height is
            // stable. Bar fill is the design's literal rgba(255,255,255,.32).
            Rectangle {
                height: 34px;
                HorizontalLayout {
                    spacing: 1px;
                    for h[i] in root.histogram: Rectangle {
                        Rectangle {
                            width: parent.width;
                            height: max(1px, h * (parent.height - 2px));
                            y: parent.height - self.height;
                            background: #ffffff52;
                        }
                    }
                }
            }

            if root.exif != "": Text {
                height: 15px;
                text: root.exif;
                font-family: Theme.font-mono;
                font-size: 10.5px;
                color: Theme.text-dim;
                vertical-alignment: center;
                overflow: elide;
            }

            if root.tags != "": Rectangle {
                height: 20px;
                background: Theme.chip-bg;
                border-radius: Theme.r-sm;
                Text {
                    text: root.tags;
                    font-family: Theme.font-mono;
                    font-size: 10.5px;
                    color: Theme.text-2;
                    x: 6px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
            Text {
                height: 15px;
                text: root.filter-label;
                font-family: Theme.font-mono;
                font-size: 10.5px;
                color: Theme.label;
                vertical-alignment: center;
            }
            Text {
                height: 15px;
                text: root.progress;
                font-family: Theme.font-mono;
                font-size: 10.5px;
                color: Theme.text-dim;
                vertical-alignment: center;
            }
        }
    }
}

// ── tag entry (DESIGN §4 2f): photo stays visible (no scrim), bottom-center panel ──
export component TagEntry inherits Rectangle {
    in-out property <string> text;
    in property <[TagSuggestion]> suggestions;
    // Which suggestion row is highlighted for keyboard nav: -1 = none (Enter
    // commits the typed text), >=0 = a row (Enter/click accepts it into the
    // current comma-segment). Mutated in Slint by Tab/Shift+Tab/Up/Down below;
    // reset to -1 from Rust whenever the suggestion list is rebuilt.
    in-out property <int> active-index: -1;
    callback changed(string);
    callback committed(string);
    callback cancelled();
    // Accept suggestion row `index` into the current segment (keeps the entry
    // open for the next tag). Distinct from `committed`, which finalizes + closes.
    callback accept-suggestion(int);

    // Fills the loupe stage but paints nothing itself — 2f explicitly keeps the photo
    // undimmed, so (unlike the brief's placeholder) there is no scrim rectangle here.
    background: transparent;

    panel := Rectangle {
        width: 380px;
        // Height follows the content (input row + N suggestion rows + hint) so
        // the panel snugly fits however many suggestions are showing. Bound to
        // the inner layout's *preferred* (intrinsic, content-derived) height —
        // not the width binding-loop this file's header warns about: the layout's
        // allocated height depends on the panel, but its preferred height (a sum
        // of fixed child heights) does not depend back on the panel.
        height: body.preferred-height;
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 14px;
        background: Theme.panel-dialog;
        border-radius: Theme.r-xl;
        border-width: 1px;
        border-color: Theme.border-strong;
        clip: true;
        // DESIGN §2.6 dialog shadow `0 16px 50px rgba(0,0,0,.6)` — a structural
        // shadow color (like the filmstrip dot-ring), not a Theme-token duplicate.
        drop-shadow-offset-y: 16px;
        drop-shadow-blur: 50px;
        drop-shadow-color: #00000099;

        // Wraps the LineEdit so Escape (unhandled by the LineEdit's own text editing)
        // bubbles up to a FocusScope that actually surrounds it — the brief's sketch put
        // `esc := FocusScope` as a *sibling* of the edit row, which per Slint's key-event
        // delivery model (a FocusScope only receives bubbled keys from a scope it
        // *surrounds*) would never see Escape while the LineEdit has focus. Fixed here.
        scope := FocusScope {
            // Escape cancels; Tab/Down move the highlight forward through the
            // suggestions (wrapping), Shift+Tab/Up move it back. These keys aren't
            // consumed by the single-line LineEdit, so they bubble up here. Enter
            // is handled on the LineEdit itself (see `accepted` below).
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.cancelled();
                    return accept;
                }
                if (root.suggestions.length > 0) {
                    if ((event.text == Key.Tab && !event.modifiers.shift) || event.text == Key.DownArrow) {
                        root.active-index = (root.active-index + 1) >= root.suggestions.length ? 0 : root.active-index + 1;
                        return accept;
                    }
                    if ((event.text == Key.Tab && event.modifiers.shift) || event.text == Key.Backtab || event.text == Key.UpArrow) {
                        root.active-index = root.active-index <= 0 ? root.suggestions.length - 1 : root.active-index - 1;
                        return accept;
                    }
                }
                return reject;
            }

            body := VerticalLayout {
                padding: 14px;
                spacing: 8px;
                alignment: start;

                input-row := Rectangle {
                    height: 34px;
                    background: Theme.input-inset;
                    border-radius: Theme.r-md;
                    border-width: 1px;
                    border-color: Theme.border-input;
                    edit := LineEdit {
                        text <=> root.text;
                        placeholder-text: "sky, portrait, keeper";
                        font-family: Theme.font-mono;
                        edited(t) => {
                            // Typing invalidates the highlight and rebuilds the
                            // list (Rust resets active-index to -1).
                            root.changed(t);
                        }
                        accepted(t) => {
                            // Enter: accept the highlighted row if one is active,
                            // else finalize the whole field.
                            if (root.active-index >= 0) {
                                root.accept-suggestion(root.active-index);
                            } else {
                                root.committed(t);
                            }
                        }
                    }
                }

                // Autocomplete rows (DESIGN §4 2f): matched prefix bolded in
                // accent-hi, count right-aligned, the active row tinted pick-blue
                // @ .22. Wrapped in a tight inner layout so rows don't inherit the
                // outer 8px spacing.
                if root.suggestions.length > 0: VerticalLayout {
                    spacing: 2px;
                    for s[i] in root.suggestions: row := Rectangle {
                        height: 24px;
                        background: i == root.active-index
                            ? Theme.tier-pick.with-alpha(0.22)
                            : (area.has-hover ? Theme.chip-bg : transparent);
                        border-radius: Theme.r-sm;
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 8px;
                            spacing: 6px;
                            alignment: stretch;
                            HorizontalLayout {
                                spacing: 0px;
                                alignment: start;
                                Text {
                                    text: s.prefix;
                                    font-family: Theme.font-mono;
                                    font-weight: 600;
                                    font-size: 12px;
                                    color: Theme.accent-hi;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: s.rest;
                                    font-family: Theme.font-mono;
                                    font-size: 12px;
                                    color: Theme.text-2;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle { }
                            Text {
                                text: s.count;
                                font-family: Theme.font-mono;
                                font-size: 11px;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                            }
                        }
                        area := TouchArea {
                            clicked => { root.accept-suggestion(i); }
                        }
                    }
                }

                Text {
                    text: "tab cycle · enter add · comma next · esc done";
                    font-family: Theme.font-mono;
                    font-size: 9.5px;
                    color: Theme.text-faint;
                }
            }
        }
    }

    init => { edit.focus(); }
}

// ── bottom-right: a faint discoverability hint that `?` opens the keymap
// (DESIGN §4 1b sketches an optional `?` button in this corner). Static — the
// `?` binding already opens the KeySheet (input.rs / main.rs). Fixed width like
// the keysheet key-caps so the centered text needs no layout-driven sizing
// (avoids the binding-loop hazard disclosed at the top of this file). app.slint
// hides it in focus mode via `visible`.
export component HudHelpHint inherits Rectangle {
    background: transparent;
    pill := Rectangle {
        x: parent.width - self.width - 14px;
        y: parent.height - self.height - 14px;
        width: 100px;
        height: 26px;
        background: Theme.panel-hud;
        border-radius: Theme.r-md;
        border-width: 1px;
        border-color: Theme.border;
        Text {
            text: "? shortcuts";
            font-family: Theme.font-mono;
            font-size: 10.5px;
            color: Theme.text-dim;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// ── focus mode's only chrome: a faint bottom-center reminder of how to leave
// (Enter toggles focus mode — see input.rs `Action::ToggleFocus`). app.slint
// shows this ONLY while `focus-mode` is on, when every other panel is hidden.
export component HudFocusHint inherits Rectangle {
    background: transparent;
    pill := Rectangle {
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 16px;
        width: 148px;
        height: 28px;
        background: Theme.panel-hud;
        border-radius: Theme.r-md;
        border-width: 1px;
        border-color: Theme.border;
        Text {
            text: "press enter to exit";
            font-family: Theme.font-mono;
            font-size: 10.5px;
            color: Theme.text-dim;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
