import { Theme } from "theme.slint";

// culler/ui/keysheet.slint — DESIGN.md §4 screen 2e: the keymap cheat-sheet,
// bound to `?` (Task 9b, optional/cheap per DESIGN §6). Static content only —
// the row text follows the canonical §9 keymap table, terse per screens/
// 2e-keymap.png where the fixed-width panel demands it (F reads "cycle tier
// filter", not the full "All → ≥Keep → …" cycle, which would overflow). The
// four groups (TIER / NAVIGATE / VIEW & TAGS / SESSION) and their row order
// follow screens/2e-keymap.png too. Gated in app.slint via `if root.help-open:
// KeySheet {}` (same pattern as TagEntry/ApplyDialog) — this component has no
// visibility property of its own.

// One key-cap + description row (§2.6/§5: chip-bg pill, border-input 1px,
// r-key radius, centered mono text; description in text-3). `cap-width`
// defaults to the spec's ~52px floor and is only widened for the few rows
// whose key-cap text doesn't fit (e.g. "← →", "ctrl S").
component KeyRow inherits HorizontalLayout {
    in property <string> keycap;
    in property <string> desc;
    in property <length> cap-width: 52px;
    spacing: 10px;

    Rectangle {
        width: root.cap-width;
        height: 26px;
        background: Theme.chip-bg;
        border-radius: Theme.r-key;
        border-width: 1px;
        border-color: Theme.border-input;
        Text {
            text: root.keycap;
            font-family: Theme.font-mono;
            font-weight: 600;
            font-size: 12px;
            color: Theme.text;
            x: (parent.width - self.width) / 2;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
    Text {
        text: root.desc;
        font-family: Theme.font-mono;
        font-size: 12px;
        color: Theme.text-3;
        vertical-alignment: center;
    }
}

// An uppercase group label (§2.5: mono 600 9.5, label color, letter-spacing
// ~.14em) followed by its rows.
component KeyGroup inherits VerticalLayout {
    in property <string> title;
    spacing: 6px;
    // Pack title + rows to the top. Without this, Slint's default `alignment:
    // stretch` spreads the rows apart whenever the enclosing grid cell is taller
    // than this group (e.g. NAVIGATE sharing a row with the taller TIER) — the
    // "NAVIGATE shifted down" bug.
    alignment: start;
    Text {
        text: root.title;
        font-family: Theme.font-mono;
        font-weight: 600;
        font-size: 9.5px;
        letter-spacing: 1.3px;
        color: Theme.label;
    }
    @children
}

export component KeySheet inherits Rectangle {
    background: Theme.scrim;

    // Modal backdrop: swallow pointer events so clicks don't fall through to the
    // filmstrip beneath (F5, mirroring CrashRecovery). Buttons/content are later
    // siblings, so they stay on top and clickable.
    TouchArea { }

    panel := Rectangle {
        width: 640px;
        // Fixed height, not bound to the content VerticalLayout's preferred-height:
        // this Rectangle isn't managed by an outer layout, so an unconstrained
        // height defaults to 100% of its parent (the full-window scrim) — the
        // same binding-loop hazard TagEntry's header comment already discloses
        // for width. Content is static (6 groups, fixed row counts), so a fixed
        // height sized to fit it is exact, not an approximation. 500px fits the
        // VIEW & TAGS group after its two added rows (enter/focus + F11).
        // +32px for r (RAW/JPEG toggle) row added in Task 8.
        height: 532px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.panel-dialog;
        border-radius: Theme.r-xl;
        border-width: 1px;
        border-color: Theme.border-strong;
        clip: true;
        // DESIGN §2.6 dialog shadow `0 16px 50px rgba(0,0,0,.6)` — a structural
        // shadow color (like the filmstrip dot-ring), not a Theme-token duplicate.
        drop-shadow-offset-y: 16px;
        drop-shadow-blur: 50px;
        drop-shadow-color: #00000099;

        VerticalLayout {
            padding: 22px;
            spacing: 18px;
            // Pack header + grid to the top rather than letting Slint's default
            // `alignment: stretch` distribute any panel slack as gaps between rows.
            // The grid's height (TIER row + VIEW&TAGS row) equals the old stacked
            // left column the 500px was sized for, so slack is ~nil either way — but
            // `start` keeps it deterministic.
            alignment: start;

            HorizontalLayout {
                Text {
                    text: "Keys";
                    font-family: Theme.font-sans;
                    font-weight: 600;
                    font-size: 15px;
                    color: Theme.text;
                }
                Rectangle { }
                Text {
                    text: "? or esc to close";
                    font-family: Theme.font-mono;
                    font-size: 10.5px;
                    color: Theme.text-faint;
                    vertical-alignment: center;
                }
            }

            // Two-by-two group grid (screens/2e-keymap.png): TIER │ NAVIGATE on the
            // top row, VIEW & TAGS │ SESSION on the bottom. A GridLayout — not two
            // independent VerticalLayout columns — is what keeps the bottom-row
            // labels aligned across columns even though TIER has one more row than
            // NAVIGATE: the second Row starts at a single y for both cells. Column
            // widths track content; `spacing-horizontal` is kept tight (20px) so both
            // columns fit inside the fixed 640px panel without clipping.
            GridLayout {
                spacing-horizontal: 20px;
                spacing-vertical: 18px;

                Row {
                    KeyGroup {
                        title: "TIER";
                        KeyRow { keycap: "1"; desc: "Keep (auto-advance)"; }
                        KeyRow { keycap: "2"; desc: "Pick (auto-advance)"; }
                        KeyRow { keycap: "3"; desc: "Best (auto-advance)"; }
                        KeyRow { keycap: "X"; desc: "Reject (auto-advance)"; }
                        KeyRow { keycap: "` / 0"; cap-width: 62px; desc: "clear → undecided (Rest)"; }
                        KeyRow { keycap: "U"; desc: "undo last tier/tag change"; }
                    }
                    KeyGroup {
                        title: "NAVIGATE";
                        KeyRow { keycap: "← →"; desc: "prev / next"; }
                        KeyRow { keycap: "space"; cap-width: 60px; desc: "next"; }
                        KeyRow { keycap: "bksp"; cap-width: 60px; desc: "prev"; }
                        KeyRow { keycap: "Tab"; desc: "next unvisited shot"; }
                        // Terse per the reference sheet — the full "All → ≥Keep → …"
                        // cycle (spec §9) overflows this two-column panel.
                        KeyRow { keycap: "F"; desc: "cycle tier filter"; }
                    }
                }

                Row {
                    KeyGroup {
                        title: "VIEW & TAGS";
                        KeyRow { keycap: "T"; desc: "tag entry (autocomplete; comma-separates)"; }
                        KeyRow { keycap: "Z"; desc: "toggle 1:1 zoom (zoom + pan persist)"; }
                        KeyRow { keycap: "r"; desc: "RAW / JPEG preview toggle"; }
                        KeyRow { keycap: "enter"; cap-width: 62px; desc: "focus mode (hide all HUD)"; }
                        KeyRow { keycap: "F11"; desc: "toggle fullscreen"; }
                        KeyRow { keycap: "?"; desc: "this help"; }
                    }
                    KeyGroup {
                        title: "SESSION";
                        KeyRow { keycap: "A"; desc: "open Apply dialog"; }
                        KeyRow { keycap: "ctrl S"; cap-width: 66px; desc: "force-save session"; }
                    }
                }
            }
        }
    }
}
