import { Theme } from "theme.slint";
import { StartupWindow } from "startup2a.slint";
import { Loupe } from "loupe.slint";
import { Filmstrip } from "filmstrip.slint";
import { FilmstripItem, ApplyPreviewUi, TagSuggestion } from "globals.slint";
import { HudTopLeft, HudTopRight, HudBottomLeft, TagEntry, HudHelpHint, HudFocusHint } from "hud.slint";
import { ApplyDialog } from "applydialog.slint";
import { KeySheet } from "keysheet.slint";
import { Toast } from "toast.slint";
import { CrashRecovery } from "crashrecovery.slint";

// Re-exported so `slint_build::compile("ui/app.slint")` (the entry file)
// exposes `StartupWindow` to Rust — only components exported from the entry
// file are reachable via `include_modules!()`/`StartupWindow::new()` (Task B,
// Phase 6b, DESIGN.md §4 2a).
export { StartupWindow }

// culler/ui/app.slint — top-level window: loupe + virtualized filmstrip (Task 8) +
// HUD overlays + tag entry (Task 9), wired to the pure input/pipeline glue in
// culler/src/ui.rs (Task 11 assembles the event loop). DESIGN.md §4 screens 1b/2f.
export component AppWindow inherits Window {
    title: "fastcull";
    // Window/taskbar icon — same "3a" keycap mark as the startup screen
    // (culler/ui/logo-3a.svg). See startup2a.slint for the X11/Wayland note.
    icon: @image-url("logo-3a.svg");
    preferred-width: 1280px;
    preferred-height: 820px;
    background: Theme.bg;

    in property <image> current-image;
    in-out property <bool> zoomed;
    in-out property <length> pan-x;
    in-out property <length> pan-y;
    // Focus/zen mode (Enter): hide every HUD panel + the filmstrip, leaving only
    // the photo and a faint exit hint. Toggled from main.rs `Action::ToggleFocus`.
    in-out property <bool> focus-mode: false;
    in property <[FilmstripItem]> film-items;
    in property <int> film-current;

    // HUD strings (Task 9's `ui::hud_text`; Task 11 wires these on navigation/edits).
    in property <string> hud-tier: "Rest";
    in property <string> hud-tags: "";
    in property <string> hud-counts: "";
    in property <string> hud-progress: "";
    in property <string> filter-label: "";
    in property <string> hud-filename: "";
    in property <bool> hud-has-raw: false;
    in property <string> hud-position: "0/0";
    // Per-tier counts pill ints backing HudTopRight's dots (task-9 amendment 5); the
    // formatted `hud-counts` string above stays for parity with the tested HudText
    // interface. Defaults 0 here — Task 11 wires both from `session.counts()`.
    in property <int> count-best: 0;
    in property <int> count-pick: 0;
    in property <int> count-keep: 0;
    in property <int> count-rest: 0;
    in property <int> count-reject: 0;
    // Bottom-left panel additions (DESIGN §4 1b, were §6 Defer): the EXIF line
    // (`ui::hud_text`) + 30 normalized luma-bar heights (`culler_core::histogram`).
    in property <string> hud-exif: "";
    in property <[float]> histogram;

    // Tag entry overlay (Task 9; Task 11 wires open/close + suggest_tags on `T`/Esc/Enter).
    in property <bool> tag-open: false;
    in-out property <string> tag-text;
    in property <[TagSuggestion]> tag-suggestions;
    // Highlighted suggestion for keyboard nav (Tab/⇧Tab/↑/↓); -1 = none.
    in-out property <int> tag-active-index: -1;
    callback tag-changed(string);
    callback tag-committed(string);
    callback tag-cancelled();
    // Accept a suggestion row into the current tag segment (keeps entry open).
    callback tag-accept-suggestion(int);

    // Keymap cheat-sheet overlay (Task 9b, DESIGN.md §4 2e), bound to `?`/Esc.
    // Static content lives entirely in keysheet.slint; main.rs only flips this.
    in-out property <bool> help-open: false;

    // Transient toast pill (Task 9b, DESIGN.md §4 2g). Visible iff toast-text
    // != ""; main.rs's `show_toast` helper sets both and restarts the
    // auto-clear timer. `show-toast` lets applyflow (a different module)
    // reach the same helper without threading an extra Rc closure through
    // `wire_apply_dialog`'s signature.
    in property <string> toast-text: "";
    in property <int> toast-code: -1;
    callback show-toast(string, int);

    callback key-pressed(string, bool) -> bool; // (text, ctrl)
    callback film-clicked(int);
    // Fired from the decode-pipeline event-loop hop (Task 11 finding 2) after a
    // prefetched neighbor's FIT-target result lands, so the filmstrip repaints
    // without waiting for the next user event (spec §12 "tiles refine lazily").
    callback thumbs-updated();

    // Apply dialog (Task 12): §6 workflow — gather/preview/confirm/apply/resume,
    // wired in `applyflow::wire_apply_dialog` (DESIGN.md §4 screens 2b/2c/2d).
    // `apply-open` itself landed in Task 11 so `InputContext::ApplyDialog` can
    // be selected on `A`.
    in-out property <bool> apply-open: false;
    in-out property <string> dest-path;
    in property <string> dest-error;
    in property <bool> preview-ready;
    in property <ApplyPreviewUi> preview;
    // Set from Rust (`applyflow::wire_apply_dialog`'s dest-changed handler)
    // when a crashed journal is detected at the chosen dest (DESIGN 2d).
    in property <bool> resume-mode;
    // Real resolved bucket names (CLI may override them), index order
    // [rejected, rest, keep, picks, bests].
    in property <[string]> bucket-names;
    // 2c progress: true while the worker thread runs apply/resume; the polled
    // journal-status text the dialog renders while running.
    in-out property <bool> apply-running;
    in property <string> apply-progress;
    callback dest-changed(string);
    callback apply-refresh();
    callback apply-confirmed();
    callback apply-cancelled();
    // Invoked from the worker's completion hop (`upgrade_in_event_loop`); its
    // handler (registered in `wire_apply_dialog`) owns all Rc-held state,
    // since Rc/RefCell must never cross the thread boundary.
    callback apply-finished(bool, string);

    // Crash-recovery startup screen (Task A3, DESIGN.md §4 2d): shown at
    // launch instead of the culling view when `startup::find_startup_crash`
    // detects an interrupted apply. Wired in `applyflow::wire_crash_recovery`.
    in-out property <bool> crash-open: false;
    in property <string> crash-journal-path;
    in property <int> crash-done: 0;
    in property <int> crash-total: 0;
    // F4: a corrupt/unreadable journal must not read as "0 of 0 moves
    // completed" (an empty no-op look-alike) — main.rs sets this true when
    // `journal_counts` fails to parse the journal, leaving done/total at 0.
    in property <bool> crash-unreadable: false;
    in-out property <string> crash-report;
    in-out property <bool> crash-report-open: false;
    in-out property <bool> crash-resuming: false;
    callback crash-show-report();
    callback crash-resume();
    // Worker completion hop (like apply-finished): registered on the UI
    // thread so its handler may touch Rc-held state.
    callback crash-finished(bool, string);

    // Returning from the tag-entry overlay: TagEntry grabs keyboard focus in its
    // `init` (edit.focus()); when it closes (`tag-open` -> false) its TextInput is
    // destroyed and nothing holds focus, so the main keyscope stopped receiving
    // keys until the user clicked the window again. Re-claim focus for keyscope on
    // close so navigation works immediately.
    changed tag-open => {
        if (!root.tag-open) { keyscope.focus(); }
    }

    forward-focus: keyscope;
    keyscope := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.LeftArrow) { return root.key-pressed("Left", event.modifiers.control) ? accept : reject; }
            if (event.text == Key.RightArrow) { return root.key-pressed("Right", event.modifiers.control) ? accept : reject; }
            if (event.text == Key.Backspace) { return root.key-pressed("Backspace", event.modifiers.control) ? accept : reject; }
            if (event.text == Key.Tab) { return root.key-pressed("Tab", event.modifiers.control) ? accept : reject; }
            if (event.text == Key.Escape) { return root.key-pressed("Escape", event.modifiers.control) ? accept : reject; }
            if (event.text == Key.Return) { return root.key-pressed("Return", event.modifiers.control) ? accept : reject; }
            if (event.text == Key.F11) { return root.key-pressed("F11", event.modifiers.control) ? accept : reject; }
            return root.key-pressed(event.text, event.modifiers.control) ? accept : reject;
        }
        VerticalLayout {
            stage := Rectangle {
                // The loupe fills the stage; HUD overlays + tag entry are later
                // siblings so they paint OVER the photo (DESIGN §4 1b/2f) instead of
                // living beside it in a side column.
                Loupe {
                    // Fill the stage explicitly. Without a width/height the Loupe
                    // takes its *preferred* size, which the 1:1-zoom Image (native
                    // pixels, ImageFit.preserve, no width/height) reports as the
                    // photo's full resolution — so the loupe ballooned to the
                    // image's native width and overflowed the window horizontally,
                    // shifting/resizing per photo. Binding to the parent stage
                    // bounds it; Loupe's own clip:true still handles 1:1 pan overflow.
                    width: parent.width;
                    height: parent.height;
                    source: root.current-image;
                    zoomed: root.zoomed;
                    pan-x <=> root.pan-x;
                    pan-y <=> root.pan-y;
                }
                HudTopLeft {
                    visible: !root.focus-mode;
                    filename: root.hud-filename;
                    has-raw: root.hud-has-raw;
                    position: root.hud-position;
                }
                HudTopRight {
                    visible: !root.focus-mode;
                    tier: root.hud-tier;
                    count-best: root.count-best;
                    count-pick: root.count-pick;
                    count-keep: root.count-keep;
                    count-rest: root.count-rest;
                    count-reject: root.count-reject;
                }
                HudBottomLeft {
                    visible: !root.focus-mode;
                    tags: root.hud-tags;
                    filter-label: root.filter-label;
                    progress: root.hud-progress;
                    exif: root.hud-exif;
                    histogram: root.histogram;
                }
                // Discoverability hint for `?` (DESIGN §4 1b bottom-right);
                // hidden in focus mode with the rest of the chrome.
                HudHelpHint {
                    visible: !root.focus-mode;
                }
                // Focus mode's only chrome: the "press enter to exit" reminder.
                if root.focus-mode: HudFocusHint { }
                if root.tag-open: TagEntry {
                    text <=> root.tag-text;
                    suggestions: root.tag-suggestions;
                    active-index <=> root.tag-active-index;
                    changed(t) => { root.tag-changed(t); }
                    committed(t) => { root.tag-committed(t); }
                    cancelled => { root.tag-cancelled(); }
                    accept-suggestion(i) => { root.tag-accept-suggestion(i); }
                }
                if root.toast-text != "": Toast {
                    text: root.toast-text;
                    code: root.toast-code;
                }
            }
            // The filmstrip is a VerticalLayout ROW, not a floating overlay, so
            // `visible:false` would leave its band empty — gate it with `if` so
            // focus mode reclaims the space and the loupe fills the whole window.
            // Height trimmed 130->72px: the tile row is only ~70px tall (56px
            // tiles + 2x7px padding), so 130px left a ~60px dead band at the
            // bottom (the reported "dead space below the filmstrip").
            if !root.focus-mode: Filmstrip {
                height: 72px;
                items: root.film-items;
                current: root.film-current;
                clicked(i) => { root.film-clicked(i); }
            }
        }

        // Full-window scrim + centered modal (DESIGN §4 2b/2c) — a sibling of
        // the VerticalLayout above rather than nested inside it, so the scrim
        // covers the filmstrip too, not just the loupe stage.
        if root.apply-open: ApplyDialog {
            dest <=> root.dest-path;
            dest-error: root.dest-error;
            preview-ready: root.preview-ready;
            preview: root.preview;
            resume-mode: root.resume-mode;
            bucket-names: root.bucket-names;
            apply-running: root.apply-running;
            apply-progress: root.apply-progress;
            dest-changed(d) => { root.dest-changed(d); }
            refresh() => { root.apply-refresh(); }
            confirmed() => { root.apply-confirmed(); }
            cancelled() => { root.apply-cancelled(); }
        }

        // Keymap cheat-sheet (DESIGN §4 2e): another full-window scrim +
        // centered modal sibling, same reasoning as ApplyDialog above.
        if root.help-open: KeySheet { }

        // Crash-recovery startup screen (DESIGN §4 2d): painted AFTER the
        // KeySheet `if` so it sits on top of everything, including any other
        // overlay — it is shown at launch, before the user can reach any of
        // those other screens anyway, but this keeps z-order unambiguous.
        if root.crash-open: CrashRecovery {
            journal-path: root.crash-journal-path;
            done: root.crash-done;
            total: root.crash-total;
            unreadable: root.crash-unreadable;
            report-text: root.crash-report;
            report-open: root.crash-report-open;
            resuming: root.crash-resuming;
            show-report() => { root.crash-show-report(); }
            resume() => { root.crash-resume(); }
        }
    }
}
