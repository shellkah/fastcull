export struct FilmstripItem {
    thumb: image,
    color-code: int,   // 0 rest/grey, 1 keep/green, 2 pick/blue, 3 best/gold, 4 reject/red
    dim: bool,         // unvisited rest -> rendered dimmer
    // M-3: no `selected` field — filmstrip.slint highlights the current tile
    // via `i == root.current` (app.slint's `film-current`, set from
    // ui.rs's `refresh_filmstrip`), which is the only mechanism actually
    // read by the .slint side.
}

// One tag-autocomplete row (DESIGN §4 2f): the matched `prefix` is bolded in
// `accent-hi`, `rest` is the remainder, `count` is how many images carry the
// tag ("sky 142"). Built by `ui::suggest_tags_counted`; when the typed segment
// is empty (show-all), `prefix` is "" and `rest` is the whole tag.
export struct TagSuggestion {
    prefix: string,
    rest: string,
    count: int,
}

export struct ApplyPreviewUi {
    rejected: int,
    rest: int,
    keep: int,
    picks: int,
    bests: int,
    collisions: int,
    skipped-sidecars: int,
    stale: int,
    leftovers: int,
    total-mb: int,
    cross-fs: bool,
    enough-space: bool,
}
